#!/usr/bin/env bash
# shellcheck disable=SC2016,SC2068


# = A list of common directories exempt from classification under installed
# directories
#
# For use with `collect_dirs()`
common_dirs=(
    usr
    usr/lib
    usr/lib/firmware
    usr/lib/pkgconfig
    usr/bin
    usr/libexec
    usr/include
    usr/sbin
    usr/share
    usr/share/doc
    usr/share/man
    usr/share/aclocal
    etc
    var
    var/cache
)


# = Determine whether a given file is a library
#
# This function uses a regex to check file extensions. It does not read magic
# bytes.
#
# == Returns
# 0 => file is a library
# 1 => file is not a library
is_lib() {
    [[ $1 =~ \.(a$|dll$|jar$|so) ]]
}


# = Determine whether a given file is a program
#
# A program is defined as an executable file directly under a directory
# '/bin/'.
#
# Note this function does not check whether a directory or file is passed. A
# file should be passed.
#
# == Returns
# 0 => file is a program
# 1 => file is not a program
is_prog() {
    [[ $1 =~ /bin/[^\/]+$ ]] &&
        [ -x "$1" ]
}


# = Determine whether a given file is firmware
#
# This function uses a regex to check file extensions. It does not read magic
# bytes.
#
# == Returns
# 0 => file is firmware
# 1 => file is not firmware
is_firm() {
    [[ $1 =~ \.(bin|bseq|ucode)$ ]]
}


# TODO: Confirm intended behavior
# = Check a file, returning 0 if the file should be documented(?)
#
# == Returns
# 0 => file should be documented
# 1 => file should not be documented
is_misc() {
    # JARs are actually internally ZIP archives... sigh
    if [[ $1 =~ \.jar$ ]]; then
        file "$1" | grep "Zip" &> /dev/null && return 0
    fi

    # ELF is binaries and shared libraries
    # scripts is all kinds of misc .sh stuff and more
    # ar archive is for static libs
    # DLL is Windows DLLs
    file "$1" | grep -E "DLL|ELF|JAR|script|ar archive" &> /dev/null || return 1
}


# = Print usage to stderr and exit with code 2
usage() {
    cat >&2 << EOF
Usage: $0 <PACKAGE_NAME> <DESTDIR>

Reference docstubgen(1) for detailed documentation
EOF
    exit 2
}


# = Print version to stderr and exit with code 0
version() {
    cat << EOF
docstubgen-ng 0.0.0-dev
EOF
    exit 0
}


# = Helper function for debugging
#
# Prints $1 to stderr, prefixed by 'DEBUG:'
dbg() {
    if [ -n "${DOCSTUBGEN_DEBUG-}" ]; then
        echo "DEBUG: $1" >&2
    fi
}


# = Joins an array with commas and "and"
#
# == Returns
# "None"              for arrays with 0 elements
# "el1"               for arrays with 1 element
# "el1 and el2"       for arrays with 2 elements
# "el1, el2, and elN" for arrays with N elements
join_array() {
    local arr=("$@")
    local n="${#arr[@]}"

    case $n in
        0)  echo "None"                     ;;
        1)  echo "${arr[0]}"                ;;
        2)  echo "${arr[0]} and ${arr[1]}"  ;;
        *)
            local joined=""
            for ((i =0; i < n - 1; i++)); do
                joined+="${arr[i]}, "
            done
            joined+="and ${arr[n-1]}"
            echo "$joined"
        ;;
    esac
}


# = Collects subdirectories into an array
#
# This function collects all leaf directories under $1 which are not in
# $common_dirs, with a maximum recursion depth defined by
# $DOCSTUBGEN_RECURSION_DEPTH, defaulting to 64.
#
# == Returns
# A sorted array of directories
collect_dirs() {
    local destdir="${1:?}"
    local dirlist
    local IFS=$'\n'

    # Find leaf directories (unix filesystems only)
    # https://stackoverflow.com/questions/4269798/use-gnu-find-to-show-only-the-leaf-directories
    #
    # NOTE: This does not find symlinks, and doing so is pretty complex, so
    # `collect_dirs()` does not discover symlinks
    readarray -t dirlist < <(
        find "$destdir" -mindepth 1 -maxdepth "${DOCSTUBGEN_RECURSION_DEPTH:-64}" -type d -links 2
    )

    # This ugly mess iterates over dirlist, and over common_dirs to determine
    # whether a directory should be retained. A directory should be retained if
    # not an element of $common_dirs.
    local trimmed_dirlist=()
    for dir in "${dirlist[@]}"; do
        dir="${dir#*"${destdir}"}"
        local retain=true
        for cdir in "${common_dirs[@]}"; do
            dbg "\$cdir = $cdir"
            dbg "\$dir  = $dir"
            if [[ $dir =~ ^/$cdir ]]; then
                dbg "matched $dir against common dir $cdir"
                retain=false
                break
            fi
        done

        dbg "\$retain is set to $retain"
        if $retain; then
            trimmed_dirlist+=("$dir")
        fi
    done

    if [ "${#trimmed_dirlist[@]}" -gt 0 ]; then
        printf "%s\n" "${trimmed_dirlist[@]}" | sort
    fi
}


# = Collects files into an array
#
# This function collects all files under $1, with a maximum recursion depth
# defined by $DOCSTUBGEN_RECURSION_DEPTH, defaulting to 64.
#
# == Returns
# filelist  : array (sorted)
collect_files() {
    local destdir="${1:?}"
    local filelist
    local IFS=$'\n'

    # Collect files and symlinks to files
    readarray -t filelist < <(
        find "$destdir" -mindepth 1 -maxdepth "${DOCSTUBGEN_RECURSION_DEPTH:-64}" -type f -o -type l -xtype f
    )

    printf "%s\n" "${filelist[@]}" | sort
}


# = Collects libraries into an array
#
# This function collects all libraries (as defined in `is_lib()`) under $1, with
# a maximum recursion depth defined by $DOCSTUBGEN_RECURSION_DEPTH, defaulting
# to 64.
#
# == Returns
# liblist   : array (sorted)
collect_libs() {
    local destdir="${1:?}"
    local liblist
    local filelist
    local IFS=$'\n'

    readarray -t filelist < <(collect_files "$destdir")

    liblist=()
    for f in "${filelist[@]}"; do
        if is_lib "$f"; then
            liblist+=("${f#*"${destdir}"}")
        fi
    done

    if [ "${#liblist[@]}" -gt 0 ]; then
        printf "%s\n" "${liblist[@]}" | sort
    fi
}


# = Collects programs into an array
#
# This function collects all programs (as defined in `is_prog()`) under $1, with
# a maximum recursion depth defined by $DOCSTUBGEN_RECURSION_DEPTH, defaulting
# to 64.
#
# == Returns
# proglist  : array (sorted)
#
# PERF: Performance could be improved by reusing filelist between functions
collect_progs() {
    local destdir="${1:?}"
    local proglist
    local filelist
    local IFS=$'\n'

    readarray -t filelist < <(collect_files "$destdir")

    proglist=()
    for f in "${filelist[@]}"; do
        if is_prog "$f"; then
            proglist+=("${f#*"${destdir}"}")
        fi
    done

    if [ "${#proglist[@]}" -gt 0 ]; then
        printf "%s\n" "${proglist[@]}" | sort
    fi
}


# = Collects firmware into an array
#
# This function collects all firmware (as defined in `is_firm()`) under $1, with
# a maximum recursion depth defined by $DOCSTUBGEN_RECURSION_DEPTH, defaulting
# to 64.
#
# == Returns
# A sorted array of unformatted firmware files
#
# PERF: Performance could be improved by reusing filelist between functions
collect_firm() {
    local destdir="${1:?}"
    local firmlist
    local filelist
    local IFS=$'\n'

    readarray -t filelist < <(collect_files "$destdir")

    firmlist=()
    for f in "${filelist[@]}"; do
        if is_firm "$f"; then
            firmlist+=("${f#*"${destdir}"}")
        fi
    done

    if [ "${#firmlist[@]}" -gt 0 ]; then
        printf "%s\n" "${firmlist[@]}" | sort
    fi
}


# = Format a library for display in the docstub
#
# This function takes a library as input and formats it according to its type. A
# formatted library is the basename of a library, without its extension, with
# its type in parentheses if not a shared library.
format_library() {
    local lib="${1##*/}"
    case "$lib" in
        *.a)   printf "%s (static)"       "${lib/.a/}"   ;;
        *.so*) printf "%s"                "${lib/.so*/}" ;;
        *.jar) printf "%s (Java library)" "${lib/.jar/}" ;;
        *.dll) printf "%s (DLL)"          "${lib/.dll/}" ;;
        *)     printf "%s"                "$lib"         ;; # TODO: Other library extensions?
    esac
}


# = Formats all libraries
#
# This function takes an array, formats each individual library, prints it on
# its own line, intersperses commas, and adds an "and"
format_all_libraries() {
    case "$#" in
        0 ) printf "          None\n" ;;
        1 ) printf "          %s\n" "$(format_library "$1")" ;;
        2 )
            printf "          %s and\n" "$(format_library "$1")"
            printf "          %s\n" "$(format_library "$2")"
        ;;
        * )
            for name in "$@"; do
                printf "          %s,\n" "$(format_library "$name")"
            done | sed -e 'x; ${s/,/, and/;p;x}; 1d' -e '$s/,//'
        ;;
    esac
}


# = Format a program for display in the docstub
#
# This function takes a program as input and formats it. A formatted program is
# its basename. Links are mentioned in parentheses.
format_program() {
    local original
    original="$(readlink "$1")"
    local prog="${1##*/}"

    original="${original##*/}"
    printf "%s" "$prog"
    [ -n "$original" ] && printf " (link to %s)" "$original"
}


# = Formats all programs
#
# This function takes an array, formats each individual program, prints it on
# its own line, intersperses commas, and adds an "and"
format_all_programs() {
    case "$#" in
        0 ) printf "          None\n" ;;
        1 ) printf "          %s\n" "$(format_library "$1")" ;;
        2 )
            printf "          %s and\n" "$(format_program "$1")"
            printf "          %s\n" "$(format_program "$2")"
        ;;
        * )
            for name in "$@"; do
                printf "          %s,\n" "$(format_program "$name")"
            done | sed -e 'x; ${s/,/, and/;p;x}; 1d' -e '$s/,//'
        ;;
    esac
}


# = Format firmware for display in the docstub
#
# This function takes firmware as input and formats it. A formatted firmware
# file is its basename. Links are mentioned in parentheses.
#
# TODO: Create a function called `format_generic()` and refactor
# `format_firmware()` and `format_program()` to use it.
format_firmware() {
    local original
    original="$(readlink "$1")"
    local firm="${1##*/}"

    original="${original##*/}"
    printf "%s" "$firm"
    [ -n "$original" ] && printf " (link to %s)" "$original"
}


# = Formats all firmware
#
# This function takes an array, formats each individual firmware, prints it on
# its own line, intersperses commas, and adds an "and"
format_all_firmware() {
    case "$#" in
        0 ) printf "          None\n" ;;
        1 ) printf "          %s\n" "$(format_library "$1")" ;;
        2 )
            printf "          %s and\n" "$(format_firmware "$1")"
            printf "          %s\n" "$(format_firmware "$2")"
        ;;
        * )
            for name in "$@"; do
                printf "          %s,\n" "$(format_firmware "$name")"
            done | sed -e 'x; ${s/,/, and/;p;x}; 1d' -e '$s/,//'
        ;;
    esac
}


# = Format a directory for display in the docstub
#
# This function does not account for links as they aren't detected by
# `collect_dirs()` anyway.
format_directory() {
    printf "%s" "$1"
}


# = Formats all directories
#
# This function takes an array, formats each individual directory, prints it on
# its own line, intersperses commas, and adds an "and"
format_all_directories() {
    case "$#" in
        0 ) printf "          None\n" ;;
        1 ) printf "          %s\n" "$(format_directory "$1")" ;;
        2 )
            printf "          %s and\n" "$(format_directory "$1")"
            printf "          %s\n" "$(format_directory "$2")"
        ;;
        * )
            for name in "$@"; do
                printf "          %s,\n" "$(format_directory "$name")"
            done | sed -e 'x; ${s/,/, and/;p;x}; 1d' -e '$s/,//'
        ;;
    esac
}


# TODO: Partition main into various helper functions because this is kind of a
# mess
# = Main

if [ -n "${DOCSTUBGEN_DEBUG-}" ]; then
    set -x
fi

for arg in "$@"; do
    case "$arg" in
        -h | --help ) usage ;;
        -V | --version ) version ;;
    esac
done

if [ "$#" -lt 2 ]; then
    usage
fi

package="$1"
destdir="$2"

readarray -t proglist < <(collect_progs "$destdir")
readarray -t firmlist < <(collect_firm "$destdir")
readarray -t liblist < <(collect_libs "$destdir")
readarray -t dirlist < <(collect_dirs "$destdir")

cat << EOF
  <sect2 role="content">
    <title>Contents</title>

    <segmentedlist>
      <segtitle>Installed Programs</segtitle>
EOF
if [ ${#firmlist[@]} -gt 0 ]; then
    dbg "Firmlist has ${#firmlist[@]} entries"
cat << EOF
      <segtitle>Installed Firmware</segtitle>
EOF
fi
cat << EOF
      <segtitle>Installed Libraries</segtitle>
      <segtitle>Installed Directories</segtitle>

      <seglistitem>
        <seg>
EOF

    format_all_programs ${proglist[@]}
cat << EOF
        </seg>
        <seg>
EOF

    if [ ${#firmlist[@]} -gt 0 ]; then
        format_all_firmware ${firmlist[@]}
cat << EOF
        </seg>
        <seg>
EOF
    fi

    format_all_libraries ${liblist[@]}
cat << EOF
        </seg>
        <seg>
EOF

    format_all_directories ${dirlist[@]}
cat << EOF
        </seg>
EOF

cat << EOF
      </seglistitem>
    </segmentedlist>

EOF

# TODO: Probably only print this if there's something to document
cat << EOF
    <variablelist>
      <bridgehead renderas="sect3">Short Descriptions</bridgehead>
      <?dbfo list-presentation="list"?>
      <?dbhtml list-presentation="table"?>

EOF

for prog in "${proglist[@]}"; do
prog="${prog##*/}"
cat << EOF
      <varlistentry id="$prog">
        <term><command>$prog</command></term>
        <listitem>
          <para>
            <!-- TODO:  --> Description for $prog
          </para>
          <indexterm zone="$package $prog">
            <primary sortas="b-$prog">$prog</primary>
          </indexterm>
        </listitem>
      </varlistentry>

EOF
done

for lib in "${liblist[@]}"; do
lib="${lib##*/}"
cat << EOF
      <varlistentry id="$lib">
        <term><filename class="libraryfile">$lib</filename></term>
        <listitem>
          <para>
            <!-- TODO:  --> Description for $lib
          </para>
          <indexterm zone="$package $lib">
            <primary sortas="c-$lib">$lib</primary>
          </indexterm>
        </listitem>
      </varlistentry>

EOF
done

cat << EOF
    </variablelist>

  </sect2>

</sect1>
EOF
