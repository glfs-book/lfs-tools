#!/usr/bin/env bash
#
# = Summary
# Script to automate scriptable tasks in package updates in SLFS and GLFS based
# on GitHub issues.
#
# The scriptable tasks pkgup performs are as follows:
# - Sync with upstream
# - Checkout to a new branch
# - Update package version in packages.ent
# - Generate changelog entry
# - Generate commit message
# - Push changes to upstream
# - Open the pull request page
#
# = Usage
# Example invocations:
# $ pkgup https://github.com/glfs-book/slfs/issues/674
# $ pkgup glfs-book/slfs/issues/674
# $ pkgup slfs/issues/674
# $ pkgup slfs/674
# $ pkgup 674

CHANGELOG="introduction/welcome/changelog.xml"

set -uo pipefail

die() {
    echo "pkgup: $1" >&2 && exit "${2:-1}"
}

warn() {
    echo "pkgup: $1" >&2
}

debug() {
    [[ -n ${DEBUG-} ]] && echo "pkgup (debug): $1" >&2
}

for prog in jq curl git; do
    $prog --version &>/dev/null || die "missing $prog" 2
done

[[ $PWD = */[gs]lfs ]] || die "please run $0 from the book's source directory" 2

# Bidirectional internal <--> pretty package name maps to be used with
# `get_internal_name`, `get_pretty_name`, and `map_package`
declare -A to_internal
declare -A to_pretty
map_package() {
    local internal pretty
    internal="$1"
    pretty="$2"
    to_internal["$pretty"]="$internal"
    to_pretty["$internal"]="$pretty"
}

# GLFS package mappings
# TODO: Finish

# SLFS package mappings
map_package btop            BTOP++
map_package tomlplusplus    toml++
